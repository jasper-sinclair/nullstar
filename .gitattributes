# Keep portable source, documentation, configuration, and scripts as LF.
* text=auto eol=lf

# Keep Windows-native command and Visual Studio project files as CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.vcxproj.filters text eol=crlf

# The generated source is hashed as a release artifact in Windows text form.
src/net.cpp text eol=crlf

# Never apply text conversion to binaries, models, or archives.
*.exe binary
*.dll binary
*.lib binary
*.a binary
*.o binary
*.obj binary
*.pdb binary
*.pgo binary
*.pgc binary
*.pgd binary
*.bin binary
*.nnue binary
*.pt binary
*.pth binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary
